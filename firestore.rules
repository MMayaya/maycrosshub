rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function owner(uid) {
      return signedIn() && request.auth.uid == uid;
    }


    function validPrivateProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid', 'title', 'firstName', 'lastName', 'email', 'phone',
          'current', 'desired', 'privacy', 'available',
          'emailVerified', 'paused', 'lastActiveAt',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (!('title' in request.resource.data)
          || request.resource.data.title in ['Mr.', 'Ms.', 'Mrs.', 'Miss', 'Mx.', 'Dr.', 'Prof.']);
    }

    function validMatchProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid', 'displayCode', 'currentProvince', 'currentDistrict',
          'desiredProvince', 'desiredDistrict', 'desiredTown',
          'phase', 'grades', 'subjects', 'postLevel', 'nearby',
          'available', 'lastActiveAt', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.displayCode is string
        && request.resource.data.currentProvince is string
        && request.resource.data.currentDistrict is string
        && request.resource.data.desiredProvince is string
        && request.resource.data.desiredDistrict is string
        && request.resource.data.desiredTown is string
        && request.resource.data.phase is string
        && request.resource.data.grades is list
        && request.resource.data.subjects is list
        && request.resource.data.postLevel is string
        && request.resource.data.nearby is bool
        && request.resource.data.available is bool;
    }

    match /profiles/{uid} {
      allow create: if owner(uid) && validPrivateProfile(uid);
      allow read: if owner(uid);
      allow update: if owner(uid) && validPrivateProfile(uid);
      allow delete: if false;

      match /savedMatches/{matchUid} {
        allow read: if owner(uid);
        allow create, update: if verified()
          && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['ownerUid', 'matchUid', 'createdAt'])
          && request.resource.data.ownerUid == uid
          && request.resource.data.matchUid == matchUid;
        allow delete: if verified() && request.auth.uid == uid;
      }

      match /blockedUsers/{blockedUid} {
        allow read: if owner(uid);
        allow create, update: if verified()
          && request.auth.uid == uid
          && blockedUid != uid
          && request.resource.data.keys().hasOnly(['ownerUid', 'blockedUid', 'createdAt'])
          && request.resource.data.ownerUid == uid
          && request.resource.data.blockedUid == blockedUid
          && request.resource.data.createdAt == request.time;
        allow delete: if verified() && request.auth.uid == uid;
      }
    }

    match /matchProfiles/{uid} {
      allow read: if verified();
      allow create, update: if owner(uid)
        && validMatchProfile(uid)
        && (!exists(/databases/$(database)/documents/moderation/$(uid))
          || get(/databases/$(database)/documents/moderation/$(uid)).data.status != 'suspended'
          || request.resource.data.available == false);
      allow delete: if false;

    }

    function usersBlocked(uidA, uidB) {
      return exists(/databases/$(database)/documents/profiles/$(uidA)/blockedUsers/$(uidB))
        || exists(/databases/$(database)/documents/profiles/$(uidB)/blockedUsers/$(uidA));
    }

    function acceptedRequestBetween(uidA, uidB) {
      return uidA != uidB
        && (
          (
            exists(/databases/$(database)/documents/requests/$(uidA + '_' + uidB))
            && get(/databases/$(database)/documents/requests/$(uidA + '_' + uidB)).data.status == 'accepted'
          ) || (
            exists(/databases/$(database)/documents/requests/$(uidB + '_' + uidA))
            && get(/databases/$(database)/documents/requests/$(uidB + '_' + uidA)).data.status == 'accepted'
          )
        );
    }

    function validSharingProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid', 'title', 'initial', 'surname', 'school',
          'email', 'phone', 'shareSchool', 'shareContact',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.title in ['Mr.', 'Ms.', 'Mrs.', 'Miss', 'Mx.', 'Dr.', 'Prof.']
        && request.resource.data.initial is string
        && request.resource.data.initial.size() > 0
        && request.resource.data.initial.size() <= 4
        && request.resource.data.surname is string
        && request.resource.data.surname.size() > 0
        && request.resource.data.surname.size() <= 80
        && request.resource.data.school is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.shareSchool is bool
        && request.resource.data.shareContact is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          (request.resource.data.shareSchool == false && request.resource.data.school == '')
          || (request.resource.data.shareSchool == true
            && request.resource.data.school.size() > 0
            && request.resource.data.school.size() <= 160)
        )
        && (
          (request.resource.data.shareContact == false
            && request.resource.data.email == ''
            && request.resource.data.phone == '')
          || (request.resource.data.shareContact == true
            && request.resource.data.email == request.auth.token.email
            && request.resource.data.phone.size() >= 7
            && request.resource.data.phone.size() <= 20)
        );
    }

    match /sharingProfiles/{uid} {
      allow read: if owner(uid)
        || (
          verified()
          && acceptedRequestBetween(request.auth.uid, uid)
          && !usersBlocked(request.auth.uid, uid)
        );

      allow create: if owner(uid)
        && validSharingProfile(uid)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if owner(uid)
        && validSharingProfile(uid)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    function requestParticipant(data) {
      return signedIn()
        && (data.fromUid == request.auth.uid || data.toUid == request.auth.uid);
    }

    function requestData(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId)).data;
    }

    function requestIsBlocked(data) {
      return usersBlocked(data.fromUid, data.toUid);
    }

    function validRequestData() {
      return request.resource.data.keys().hasOnly([
          'fromUid', 'toUid', 'status', 'matchScore',
          'introMessage', 'createdAt', 'updatedAt', 'respondedAt'
        ])
        && request.resource.data.fromUid is string
        && request.resource.data.toUid is string
        && request.resource.data.matchScore is int
        && request.resource.data.matchScore >= 0
        && request.resource.data.matchScore <= 100
        && (!('introMessage' in request.resource.data)
          || (request.resource.data.introMessage is string
            && request.resource.data.introMessage.size() <= 500));
    }

    function validRequestTransition() {
      return (
          resource.data.status == 'pending'
          && request.auth.uid == resource.data.toUid
          && request.resource.data.status in ['accepted', 'declined']
        ) || (
          resource.data.status == 'pending'
          && request.auth.uid == resource.data.fromUid
          && request.resource.data.status == 'cancelled'
        ) || (
          resource.data.status in ['accepted', 'declined', 'cancelled']
          && request.resource.data.status == 'archived'
          && requestParticipant(resource.data)
        );
    }

    function validRequestStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'respondedAt'])
        && validRequestTransition()
        && (request.resource.data.status != 'accepted' || !requestIsBlocked(resource.data));
    }

    function validRequestResend() {
      return resource.data.status in ['declined', 'cancelled', 'archived']
        && request.auth.uid == resource.data.fromUid
        && request.resource.data.status == 'pending'
        && request.resource.data.respondedAt == null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'matchScore', 'introMessage', 'createdAt', 'updatedAt', 'respondedAt'])
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && exists(/databases/$(database)/documents/matchProfiles/$(resource.data.toUid))
        && get(/databases/$(database)/documents/matchProfiles/$(resource.data.toUid)).data.available == true
        && !requestIsBlocked(resource.data)
        && (!exists(/databases/$(database)/documents/moderation/$(request.auth.uid))
          || get(/databases/$(database)/documents/moderation/$(request.auth.uid)).data.status != 'suspended')
        && (!exists(/databases/$(database)/documents/moderation/$(resource.data.toUid))
          || get(/databases/$(database)/documents/moderation/$(resource.data.toUid)).data.status != 'suspended');
    }

    match /requests/{requestId} {
      allow create: if verified()
        && validRequestData()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.respondedAt == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && requestId == request.auth.uid + '_' + request.resource.data.toUid
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && exists(/databases/$(database)/documents/matchProfiles/$(request.resource.data.toUid))
        && get(/databases/$(database)/documents/matchProfiles/$(request.resource.data.toUid)).data.available == true
        && !requestIsBlocked(request.resource.data)
        && (!exists(/databases/$(database)/documents/moderation/$(request.auth.uid))
          || get(/databases/$(database)/documents/moderation/$(request.auth.uid)).data.status != 'suspended')
        && (!exists(/databases/$(database)/documents/moderation/$(request.resource.data.toUid))
          || get(/databases/$(database)/documents/moderation/$(request.resource.data.toUid)).data.status != 'suspended');

      allow read: if verified() && requestParticipant(resource.data);

      allow update: if verified()
        && requestParticipant(resource.data)
        && validRequestData()
        && (validRequestStatusUpdate() || validRequestResend());

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if verified()
          && requestData(requestId).status == 'accepted'
          && requestParticipant(requestData(requestId))
          && !requestIsBlocked(requestData(requestId));

        allow create: if verified()
          && requestData(requestId).status == 'accepted'
          && requestParticipant(requestData(requestId))
          && !requestIsBlocked(requestData(requestId))
          && request.resource.data.keys().hasOnly([
              'senderUid', 'text', 'createdAt'
            ])
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt == request.time;

        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if verified()
        && request.resource.data.keys().hasOnly([
          'reporterUid', 'reportedUid', 'requestId', 'reason',
          'details', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.requestId is string
        && request.resource.data.reason is string
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 1000
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow read: if verified() && resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /moderation/{uid} {
      allow read: if owner(uid);
      allow create, update, delete: if false;
    }
  }
}
